# MemoryShield AI - Production Environment

# Database (Provided by Render)
# DATABASE_URL is automatically set by Render PostgreSQL

# Redis (Provided by Render)
# REDIS_URL is automatically set by Render Redis

# Server
DEBUG=false
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000

# API Keys (Set these in Render dashboard)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...

# Features
ENABLE_AI_ANALYST=true
ENABLE_THREAT_FAMILIES=true
ENABLE_AUTOMATED_RESPONSES=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
