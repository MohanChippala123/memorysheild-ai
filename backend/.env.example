# MemoryShield AI - Backend Environment Variables

# Database
DATABASE_URL=postgresql+asyncpg://memoryshield:password@localhost:5432/memoryshield
DB_PASSWORD=secure_password_change_me
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600
SIMILARITY_CACHE_TTL=86400

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (Optional)
ANTHROPIC_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Security
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Flags
ENABLE_AI_ANALYST=true
ENABLE_THREAT_FAMILIES=true
ENABLE_AUTOMATED_RESPONSES=false
